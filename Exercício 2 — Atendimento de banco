import java.util.*;

class Cliente {
    String nome;
    int senha;

    Cliente(String nome, int senha) {
        this.nome = nome;
        this.senha = senha;
    }
}

public class Banco {
    public static void main(String[] args) {
        Queue<Cliente> fila = new LinkedList<>();

        fila.add(new Cliente("Ana", 1));
        fila.add(new Cliente("João", 2));
        fila.add(new Cliente("Carlos", 3));
        fila.add(new Cliente("Maria", 4));
        fila.add(new Cliente("Pedro", 5));
        fila.add(new Cliente("Lucas", 6));

        while (!fila.isEmpty()) {
            Cliente c = fila.poll();
            System.out.println("Chamando senha: " + c.senha);
        }

        System.out.println("Fila vazia!");
    }
}
